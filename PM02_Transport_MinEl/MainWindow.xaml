<Window x:Class="PM02_Transport_MinEl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PM02_Transport_MinEl"
        mc:Ignorable="d"
        Title="Транспортная задача (Метод минимальных элементов)" Height="600" Width="950">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель управления размерами -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Поставщики:" VerticalAlignment="Center" Margin="0,0,5,0" />
            <TextBox x:Name="SuppliersBox" Width="50" Text="3" Margin="0,0,15,0" Background="LightGray"/>
            <TextBlock Text="Потребители:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="ConsumersBox" Width="50" Text="4" Margin="0,0,15,0" Background="LightBlue"/>
            <Button Content="Создать таблицу" Click="CreateTable_Click" Margin="0,0,5,0"/>
            <TextBlock Text="Подсказка распредел.:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <TextBox x:Name="DistributionHintBox" Width="50" Text="0" ToolTip="Значение для фиктивных ячеек" Margin="0,0,5,0"/>

            <Separator Margin="10,0,10,0" Width="1" Background="Gray"/>

            <Button Content="Импорт" Click="ImportFromExcel_Click" Margin="0,0,5,0" Padding="10,2" Background="LightSkyBlue"/>
            <Button Content="Экспорт" Click="ExportToExcel_Click" Margin="0,0,5,0" Padding="10,2" Background="LightSkyBlue"/>

            <Separator Margin="10,0,10,0" Width="1" Background="Gray"/>

            <Button Content="Балансировать" Click="BalanceProblem_Click" Background="LightBlue" Margin="0,0,5,0"/>
            <Button Content="Очистить" Click="ClearTable_Click" Background="LightCoral" Margin="0,0,5,0"/>
        </StackPanel>

        <!-- Основная таблица -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MatrixGrid">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- Заголовки потребителей -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,5">
            <TextBlock Text="" Margin="65,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
            <ItemsControl x:Name="ColumnHeaders">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Vertical">
            <Button Content="Решить задачу (Минимальных элементов)" Click="Solve_Click" 
                HorizontalAlignment="Center" Margin="0,10,0,10" Padding="20,5"
                Background="LightGreen" FontWeight="Bold" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>
